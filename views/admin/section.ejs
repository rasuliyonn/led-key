      <div class="admin-field-row">
        <div class="admin-field"><label>Тип лого</label><select name="logo_type"><option value="image"<%= c.logo_type==='image'?' selected':'' %>>Картинка</option><option value="text"<%= c.logo_type==='text'?' selected':'' %>>Текст</option></select></div>
        <div class="admin-field"><label>Лого</label><input type="hidden" name="logo_path" value="<%= c.logo_path || '' %>"><button class="admin-btn admin-btn--sm" onclick="uploadForField(this)">📁 Загрузить</button><% if (c.logo_path) { %><div class="upload-preview" style="margin-top:8px"><img src="/<%= c.logo_path %>" style="max-width:120px;max-height:80px;border-radius:8px;object-fit:cover;"></div><% } %></div>
        <div class="admin-field"><label>Лого (текст)</label><input type="text" name="logo_text" value="<%= c.logo_text || '' %>"></div>
      </div>
      <div class="admin-field-row">
        <div class="admin-field"><label>Заголовок</label><input type="text" name="title" value="<%= c.title %>"></div>
        <div class="admin-field"><label>Период</label><input type="text" name="period" value="<%= c.period %>"></div>
      </div>
      <div class="admin-field"><label>Услуги</label><input type="text" name="services" value="<%= c.services %>"></div>
      <div class="admin-field-row">
        <div class="admin-field"><label>Стоимость лида</label><input type="text" name="lead_cost" value="<%= c.lead_cost %>"></div>
        <div class="admin-field"><label>Объем лидов</label><input type="text" name="lead_volume" value="<%= c.lead_volume %>"></div>
        <div class="admin-field"><label>Ед. изм.</label><input type="text" name="lead_unit" value="<%= c.lead_unit %>"></div>
      </div>
      <div class="admin-field"><label>Ссылка</label><input type="text" name="link" value="<%= c.link || '' %>"></div>
      <div class="admin-item__actions">
        <button class="admin-btn admin-btn--sm" onclick="saveItem(this)">Сохранить</button>
        <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteItem(this)">Удалить</button>
      </div>
    </div>
    <% }); %>
  </div>
  <button class="admin-btn admin-btn--add" onclick="addItem('cases', {logo_type:'text', logo_text:'Название', title:'Ниша', period:'2024', services:'Описание', lead_cost:'0 ₽', lead_volume:'0', lead_unit:'шт/мес', sort_order:99})">+ Добавить кейс</button>
</div>
<% } %>

<% if (sectionId === 'reviews') { %>
<div class="admin-panel">
  <h2 class="admin-panel__title">Отзывы (текст + видео)</h2>
  <div class="admin-items" data-table="reviews">
    <% if(items.reviews) items.reviews.forEach(function(r) { %>
    <div class="admin-item" data-id="<%= r.id %>">
      <div class="admin-field-row">
        <div class="admin-field"><label>Тип</label><select name="type"><option value="text"<%= r.type==='text'?' selected':'' %>>Текст</option><option value="video"<%= r.type==='video'?' selected':'' %>>Видео</option></select></div>
        <div class="admin-field"><label>Имя</label><input type="text" name="name" value="<%= r.name %>"></div>
        <div class="admin-field"><label>Источник</label><input type="text" name="source" value="<%= r.source || '' %>"></div>
        <div class="admin-field"><label>Цвет</label><select name="color"><option value="green"<%= r.color==='green'?' selected':'' %>>Зелёный</option><option value="blue"<%= r.color==='blue'?' selected':'' %>>Синий</option><option value="purple"<%= r.color==='purple'?' selected':'' %>>Фиолетовый</option></select></div>
      </div>
      <div class="admin-field"><label>Текст отзыва</label><textarea name="text" rows="3"><%= r.text || '' %></textarea></div>
      <div class="admin-field-row">
        <div class="admin-field"><label>Видео URL (YouTube/Rutube)</label><input type="text" name="video_url" value="<%= r.video_url || '' %>"></div>
        <div class="admin-field"><label>Видео файл</label><input type="hidden" name="video_path" value="<%= r.video_path || '' %>"><button class="admin-btn admin-btn--sm" onclick="uploadForField(this)">📁 Загрузить</button><% if (r.video_path) { %><div class="upload-preview" style="margin-top:8px"><video src="/<%= r.video_path %>" controls style="max-width:280px;max-height:180px;border-radius:8px;"></video></div><% } %></div>
      </div>
      <div class="admin-field"><label>Ссылка на оригинал</label><input type="text" name="link" value="<%= r.link || '' %>"></div>
      <div class="admin-item__actions">
        <button class="admin-btn admin-btn--sm" onclick="saveItem(this)">Сохранить</button>
        <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteItem(this)">Удалить</button>
      </div>
    </div>
    <% }); %>
  </div>
  <button class="admin-btn admin-btn--add" onclick="addItem('reviews', {type:'text', name:'Имя', source:'', text:'Текст отзыва', color:'green', sort_order:99})">+ Добавить отзыв</button>
</div>
<% } %>

