<div class="admin-panel">
  <h2 class="admin-panel__title">Вопросы и ответы</h2>
  <div class="admin-items" data-table="faq_items">
    <% if(items.faqItems) items.faqItems.forEach(function(f) { %>
    <div class="admin-item" data-id="<%= f.id %>">
      <div class="admin-field"><label>Вопрос</label><input type="text" name="question" value="<%= f.question %>"></div>
      <div class="admin-field"><label>Ответ (HTML разрешён)</label><textarea name="answer" rows="3"><%= f.answer %></textarea></div>
      <div class="admin-item__actions">
        <button class="admin-btn admin-btn--sm" onclick="saveItem(this)">Сохранить</button>
        <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteItem(this)">Удалить</button>
      </div>
    </div>
    <% }); %>
  </div>
  <button class="admin-btn admin-btn--add" onclick="addItem('faq_items', {question:'Новый вопрос?', answer:'Ответ', sort_order:99})">+ Добавить вопрос</button>
</div>
<% } %>

<% if (sectionId === 'footer') { %>
<div class="admin-panel">
  <h2 class="admin-panel__title">Навигация футера</h2>
  <div class="admin-items" data-table="nav_links">
    <% if(items.navLinks) items.navLinks.forEach(function(l) { %>
    <div class="admin-item" data-id="<%= l.id %>">
      <div class="admin-field-row">
        <div class="admin-field"><label>Текст</label><input type="text" name="label" value="<%= l.label %>"></div>
        <div class="admin-field"><label>Ссылка</label><input type="text" name="href" value="<%= l.href %>"></div>
        <button class="admin-btn admin-btn--sm" onclick="saveItem(this)">💾</button>
        <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteItem(this)">✕</button>
      </div>
    </div>
    <% }); %>
  </div>
</div>
<div class="admin-panel">
  <h2 class="admin-panel__title">Юридические ссылки</h2>
  <div class="admin-items" data-table="legal_links">
    <% if(items.legalLinks) items.legalLinks.forEach(function(l) { %>
    <div class="admin-item" data-id="<%= l.id %>">
      <div class="admin-field-row">
        <div class="admin-field"><label>Текст</label><input type="text" name="label" value="<%= l.label %>"></div>
        <div class="admin-field"><label>URL</label><input type="text" name="url" value="<%= l.url %>"></div>
        <button class="admin-btn admin-btn--sm" onclick="saveItem(this)">💾</button>
        <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteItem(this)">✕</button>
      </div>
    </div>
    <% }); %>
  </div>
  <button class="admin-btn admin-btn--add" onclick="addItem('legal_links', {label:'Новая ссылка', url:'https://', sort_order:99})">+ Добавить</button>
</div>
<% } %>

<% if (['cta1','cta2','final_cta'].includes(sectionId)) { %>
<div class="admin-panel">
  <p class="admin-hint">Настройки формы (тексты кнопок, сообщения успеха) находятся в полях "extra" выше.</p>
</div>
<% } %>
