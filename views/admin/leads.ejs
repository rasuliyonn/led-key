<h1 class="admin-page-title">Заявки (<%= leads.length %>)</h1>
<div class="admin-panel">
  <% if (leads.length === 0) { %>
  <p>Заявок пока нет.</p>
  <% } else { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Дата</th><th>Имя</th><th>Телефон</th><th>Ссылка</th><th>Источник</th><th>Статус</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% leads.forEach(function(lead) { %>
      <tr class="<%= lead.is_read ? '' : 'admin-table__row--unread' %>" data-id="<%= lead.id %>">
        <td data-label="Дата"><%= lead.created_at %></td>
        <td data-label="Имя"><%= lead.name %></td>
        <td data-label="Телефон"><a href="tel:<%= lead.phone %>"><%= lead.phone %></a></td>
        <td data-label="Ссылка"><%= lead.link || '—' %></td>
        <td data-label="Источник"><%= lead.form_source %></td>
        <td data-label="Статус"><%= lead.is_read ? 'Прочитано' : 'Новая' %></td>
        <td>
          <% if (!lead.is_read) { %>
          <button class="admin-btn admin-btn--sm" onclick="markRead(<%= lead.id %>, this)">✓</button>
          <% } %>
          <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteLead(<%= lead.id %>, this)">✕</button>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<script>
function markRead(id, btn) {
  fetch('/api/leads/' + id + '/read', { method: 'PUT' })
    .then(r => r.json()).then(function() { btn.closest('tr').classList.remove('admin-table__row--unread'); btn.remove(); });
}
function deleteLead(id, btn) {
  if (!confirm('Удалить заявку?')) return;
  fetch('/api/leads/' + id, { method: 'DELETE' })
    .then(r => r.json()).then(function() { btn.closest('tr').remove(); });
}
</script>
