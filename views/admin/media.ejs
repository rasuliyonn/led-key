<h1 class="admin-page-title">Медиа-библиотека</h1>
<div class="admin-panel">
  <div class="admin-upload-zone">
    <input type="file" id="mediaUpload" accept="image/*,video/mp4" style="display:none">
    <button class="admin-btn" onclick="document.getElementById('mediaUpload').click()">Загрузить файл</button>
  </div>
  <div class="admin-media-grid" id="mediaGrid">
    <% files.forEach(function(f) { %>
    <div class="admin-media-item" data-filename="<%= f.name %>">
      <img src="<%= f.path %>" alt="<%= f.name %>">
      <div class="admin-media-item__info">
        <code><%= f.path %></code>
        <button class="admin-btn admin-btn--sm admin-btn--danger" onclick="deleteMedia('<%= f.name %>', this)">Удалить</button>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<script>
document.getElementById('mediaUpload').addEventListener('change', function() {
  var file = this.files[0];
  if (!file) return;
  var fd = new FormData();
  fd.append('file', file);
  fetch('/api/upload', { method: 'POST', body: fd })
    .then(r => r.json())
    .then(function(data) { if (data.ok) location.reload(); else alert(data.error); });
});
function deleteMedia(filename, btn) {
  if (!confirm('Удалить файл?')) return;
  fetch('/api/upload/' + filename, { method: 'DELETE' })
    .then(r => r.json())
    .then(function() { btn.closest('.admin-media-item').remove(); });
}
</script>
